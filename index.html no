<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GT7 Leaderboard — Suzuka Circuit</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Rajdhani:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #c9a84c; --silver: #8a9ab8; --bronze: #a0622a;
    --bg: #060910; --bg2: #0a0f1c; --bg3: #0d1425;
    --text: #dde4f0; --text-dim: #4a5a7a; --red: #e24b4a;
    --border: rgba(201,168,76,0.15);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'Rajdhani', sans-serif; min-height: 100vh; overflow-x: hidden; }
  body::before { content: ''; position: fixed; inset: 0; background-image: linear-gradient(rgba(201,168,76,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(201,168,76,0.03) 1px, transparent 1px); background-size: 40px 40px; pointer-events: none; z-index: 0; }
  .wrapper { position: relative; z-index: 1; max-width: 1400px; margin: 0 auto; padding: 28px 24px; }

  /* HEADER */
  .header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 32px; padding-bottom: 20px; border-bottom: 1px solid var(--border);
    position: relative; overflow: visible;
  }
  .header-left { display: flex; align-items: center; gap: 20px; }
  .header-center { display: flex; align-items: center; gap: 20px; flex: 1; padding: 0 30px; }
  .header-right { display: flex; align-items: center; gap: 16px; }

  /* Circuit */
  .circuit-box { background: var(--bg3); border: 1px solid rgba(201,168,76,0.2); border-radius: 12px; padding: 10px 14px; display: flex; flex-direction: column; align-items: center; gap: 5px; }
  .circuit-box img { width: 90px; height: 130px; object-fit: contain; display: block; filter: drop-shadow(0 0 6px rgba(201,168,76,0.2)); }
  .circuit-label { font-family: 'Orbitron', monospace; font-size: 7px; color: var(--gold); letter-spacing: 2px; text-transform: uppercase; }

  /* Titres */
  .title-main { font-family: 'Orbitron', monospace; font-size: 26px; font-weight: 900; color: var(--gold); letter-spacing: 4px; text-transform: uppercase; line-height: 1; }
  .title-sub { font-size: 11px; color: var(--text-dim); letter-spacing: 5px; text-transform: uppercase; margin-top: 6px; font-family: 'Orbitron', monospace; }

  /* Pilote */
  .pilot-wrap {
    display: flex; align-items: flex-end; gap: 14px;
    background: linear-gradient(135deg, rgba(201,168,76,0.06) 0%, transparent 60%);
    border: 1px solid rgba(201,168,76,0.12);
    border-radius: 12px;
    padding: 8px 16px 0 12px;
    position: relative;
    overflow: hidden;
  }
  .pilot-wrap::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at bottom center, rgba(201,168,76,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .pilot-img {
    height: 120px;
    width: auto;
    display: block;
    filter: drop-shadow(0 0 12px rgba(201,168,76,0.3));
    animation: pilotIn 0.8s ease forwards;
    transform-origin: bottom center;
  }
  @keyframes pilotIn {
    from { opacity: 0; transform: translateY(20px) scale(0.95); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  .pilot-info {
    padding-bottom: 10px;
  }
  .pilot-tag {
    font-family: 'Orbitron', monospace;
    font-size: 8px;
    color: var(--gold);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .pilot-name-tag {
    font-family: 'Orbitron', monospace;
    font-size: 11px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 1px;
  }

  /* Live badge */
  .live-badge { display: flex; align-items: center; gap: 8px; background: rgba(226,75,74,0.1); border: 1px solid rgba(226,75,74,0.4); border-radius: 6px; padding: 8px 14px; font-family: 'Orbitron', monospace; font-size: 10px; color: var(--red); letter-spacing: 3px; }
  .live-dot { width: 8px; height: 8px; background: var(--red); border-radius: 50%; animation: pulse 1.4s ease-in-out infinite; }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.3;transform:scale(0.8)} }
  .refresh-info { font-size: 11px; color: var(--text-dim); letter-spacing: 1px; }

  /* LOADING */
  .state-msg { text-align: center; padding: 60px 20px; font-family: 'Orbitron', monospace; font-size: 13px; color: var(--text-dim); letter-spacing: 2px; }
  .spinner { width: 36px; height: 36px; border: 2px solid var(--border); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 16px; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* PODIUM */
  .podium-section { display: grid; grid-template-columns: 1fr 1.1fr 1fr; gap: 14px; margin-bottom: 32px; align-items: end; }
  .podium-card { border-radius: 14px; padding: 20px 16px 16px; text-align: center; border: 1px solid; position: relative; animation: fadeUp 0.5s ease both; }
  @keyframes fadeUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
  .podium-card.p1 { background: linear-gradient(160deg,#120e00,var(--bg2)); border-color: var(--gold); padding-top: 28px; animation-delay:.1s }
  .podium-card.p2 { background: var(--bg2); border-color: rgba(138,154,184,0.4); animation-delay:.2s }
  .podium-card.p3 { background: var(--bg2); border-color: rgba(160,98,42,0.4); animation-delay:.3s }
  .podium-badge { position:absolute; top:-16px; left:50%; transform:translateX(-50%); width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Orbitron',monospace; font-size:12px; font-weight:900; }
  .p1 .podium-badge { background:var(--gold); color:var(--bg); box-shadow:0 0 16px rgba(201,168,76,0.5) }
  .p2 .podium-badge { background:var(--silver); color:var(--bg) }
  .p3 .podium-badge { background:var(--bronze); color:var(--bg) }
  .podium-name { font-family:'Orbitron',monospace; font-size:13px; font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-bottom:4px }
  .p1 .podium-name { color:var(--gold); font-size:15px }
  .p2 .podium-name { color:var(--silver) }
  .p3 .podium-name { color:var(--bronze) }
  .podium-company { font-size:10px; color:var(--text-dim); letter-spacing:3px; text-transform:uppercase; margin-bottom:5px }
  .podium-car-p { font-size:9px; color:var(--text-dim); letter-spacing:0.5px; text-transform:uppercase; margin-bottom:10px; font-style:italic }
  .podium-time { font-family:'Orbitron',monospace; font-size:22px; font-weight:900; letter-spacing:2px; margin-bottom:6px }
  .p1 .podium-time { color:#fff; font-size:26px }
  .p2 .podium-time { color:var(--silver); font-size:20px }
  .p3 .podium-time { color:var(--bronze); font-size:20px }
  .podium-delta { font-family:'Orbitron',monospace; font-size:10px; letter-spacing:1px; margin-bottom:4px }
  .p1 .podium-delta { color:var(--gold) }
  .p2 .podium-delta { color:var(--silver) }
  .p3 .podium-delta { color:var(--bronze) }

  /* TABLE */
  .table-wrap { background:var(--bg2); border:1px solid var(--border); border-radius:14px; overflow:hidden; animation:fadeUp 0.5s ease 0.4s both; }
  .table-head, .table-row { display: grid; grid-template-columns: 46px 1fr 170px 140px 120px 86px; gap: 8px; padding: 10px 20px; }
  .table-head { background: rgba(201,168,76,0.06); border-bottom:1px solid var(--border); font-family:'Orbitron',monospace; font-size:8px; color:var(--text-dim); letter-spacing:3px; text-transform:uppercase; }
  .table-row { border-bottom:1px solid rgba(201,168,76,0.07); transition:background 0.2s; animation:fadeUp 0.4s ease both; padding: 13px 20px; }
  .table-row:last-child { border-bottom:none }
  .table-row:hover { background:rgba(201,168,76,0.04) }
  .table-row.top { background:rgba(201,168,76,0.04) }
  .col-rank { font-family:'Orbitron',monospace; font-size:14px; font-weight:700; text-align:center; align-self:center }
  .rank-1{color:var(--gold)} .rank-2{color:var(--silver)} .rank-3{color:var(--bronze)} .rank-other{color:var(--text-dim)}
  .col-name { font-size:15px; font-weight:600; color:var(--text); letter-spacing:0.5px; text-transform:uppercase; align-self:center }
  .col-name.top { color:#fff }
  .col-car { font-size:11px; color:var(--text-dim); letter-spacing:0.3px; text-transform:uppercase; align-self:center; font-style:italic }
  .col-company { font-size:11px; color:var(--text-dim); letter-spacing:2px; text-transform:uppercase; align-self:center; text-align:right }
  .col-time { font-family:'Orbitron',monospace; font-size:13px; font-weight:600; color:#fff; letter-spacing:1px; align-self:center; text-align:right }
  .col-delta { font-family:'Orbitron',monospace; font-size:11px; color:var(--text-dim); letter-spacing:0.5px; align-self:center; text-align:right }
  .leader-pill { display:inline-block; background:rgba(201,168,76,0.15); color:var(--gold); border:1px solid rgba(201,168,76,0.3); border-radius:4px; padding:2px 8px; font-size:8px; letter-spacing:2px }

  /* FOOTER */
  .footer { display:flex; justify-content:space-between; align-items:center; margin-top:24px; padding-top:16px; border-top:1px solid var(--border); font-size:10px; color:var(--text-dim); letter-spacing:2px; font-family:'Orbitron',monospace }
</style>
</head>
<body>
<div class="wrapper">
  <div class="header">
    <div class="header-left">
      <div class="circuit-box">
        <img src="data:image/png;base64," alt="Suzuka Circuit"/>
        <div class="circuit-label">Suzuka Circuit · Japan</div>
      </div>
      <div>
        <div class="title-main">GT7 Leaderboard</div>
        <div class="title-sub">Gran Turismo 7 — Challenge Corporate</div>
      </div>
    </div>

    <!-- PILOTE SAM -->
    <div class="header-center">
      <div class="pilot-wrap">
        <img class="pilot-img" src="data:image/png;base64," alt="Pilote SAM"/>
        <div class="pilot-info">
          <div class="pilot-tag">Official Driver</div>
          <div class="pilot-name-tag">SAM Racing</div>
        </div>
      </div>
    </div>

    <div class="header-right">
      <div class="refresh-info" id="last-update">Chargement...</div>
      <div class="live-badge"><div class="live-dot"></div>LIVE</div>
    </div>
  </div>

  <div id="podium-section" class="podium-section" style="display:none"></div>

  <div id="table-wrap" class="table-wrap" style="display:none">
    <div class="table-head">
      <div>#</div>
      <div>Pilote</div>
      <div>Voiture</div>
      <div style="text-align:right">Entreprise</div>
      <div style="text-align:right">Meilleur temps</div>
      <div style="text-align:right">Delta</div>
    </div>
    <div class="table-body" id="table-body"></div>
  </div>

  <div id="state-msg" class="state-msg">
    <div class="spinner"></div>
    CHARGEMENT DES DONNÉES...
  </div>

  <div class="footer">
    <div>GT7 CHALLENGE — SUZUKA CIRCUIT</div>
    <div id="participant-count"></div>
  </div>
</div>

<script>
const SHEET_ID = '18noW4f79z97c8ukjiqNaA6L3QgAVEoNECBuEIVwj524';
const SHEET_NAME = 'Feuille 1';
const REFRESH_MS = 60000;

async function fetchData() {
  const sheetsUrl = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=${encodeURIComponent(SHEET_NAME)}`;
  const url = `https://api.allorigins.win/get?url=${encodeURIComponent(sheetsUrl)}`;
  const res = await fetch(url);
  const data = await res.json();
  const text = data.contents;
  const json = JSON.parse(text.match(/google\.visualization\.Query\.setResponse\(([\s\S]*)\)/)[1]);
  const rows = json.table.rows;
  const players = [];
  for (const row of rows) {
    const rang = row.c[0]?.v;
    const nom  = row.c[1]?.v;
    if (!rang || !nom) continue;
    players.push({ rang: Math.round(rang), nom, entreprise: row.c[2]?.v||'', voiture: row.c[4]?.v||'', temps: row.c[5]?.v||'', delta: row.c[6]?.v||'' });
  }
  players.sort((a,b) => a.rang - b.rang);
  return players;
}

function renderPodium(players) {
  const top3 = players.slice(0,3);
  const order = [top3[1], top3[0], top3[2]].filter(Boolean);
  const classes = ['p2','p1','p3'], nums = ['2','1','3'];
  const section = document.getElementById('podium-section');
  section.innerHTML = '';
  order.forEach((p,i) => {
    if (!p) return;
    const card = document.createElement('div');
    card.className = `podium-card ${classes[i]}`;
    card.style.animationDelay = `${0.1+i*0.1}s`;
    card.innerHTML = `
      <div class="podium-badge">${nums[i]}</div>
      <div class="podium-name">${p.nom}</div>
      <div class="podium-company">${p.entreprise}</div>
      <div class="podium-car-p">${p.voiture}</div>
      <div class="podium-time">${p.temps}</div>
      <div class="podium-delta">${p.delta || 'LEADER'}</div>
    `;
    section.appendChild(card);
  });
  section.style.display = 'grid';
}

function renderTable(players) {
  const body = document.getElementById('table-body');
  body.innerHTML = '';
  players.forEach((p,i) => {
    const row = document.createElement('div');
    const isTop = p.rang <= 3;
    row.className = `table-row${isTop?' top':''}`;
    row.style.animationDelay = `${0.4+i*0.05}s`;
    const rankClass = p.rang===1?'rank-1':p.rang===2?'rank-2':p.rang===3?'rank-3':'rank-other';
    const deltaHtml = p.rang===1 ? `<span class="leader-pill">LEADER</span>` : `<span>${p.delta}</span>`;
    row.innerHTML = `
      <div class="col-rank ${rankClass}">${p.rang}</div>
      <div class="col-name${isTop?' top':''}">${p.nom}</div>
      <div class="col-car">${p.voiture}</div>
      <div class="col-company">${p.entreprise}</div>
      <div class="col-time">${p.temps}</div>
      <div class="col-delta">${deltaHtml}</div>
    `;
    body.appendChild(row);
  });
  document.getElementById('table-wrap').style.display = 'block';
}

function updateTimestamp() {
  const now = new Date();
  document.getElementById('last-update').textContent = `Mis à jour ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}:${String(now.getSeconds()).padStart(2,'0')}`;
}

async function refresh() {
  try {
    const players = await fetchData();
    if (!players.length) { document.getElementById('state-msg').innerHTML='<div style="font-size:13px;color:var(--text-dim);letter-spacing:2px">AUCUNE DONNÉE DISPONIBLE</div>'; return; }
    document.getElementById('state-msg').style.display = 'none';
    renderPodium(players); renderTable(players);
    document.getElementById('participant-count').textContent = `${players.length} PARTICIPANT${players.length>1?'S':''}`;
    updateTimestamp();
  } catch(e) {
    document.getElementById('state-msg').innerHTML = `<div style="color:var(--red);font-size:12px;letter-spacing:2px">ERREUR DE CHARGEMENT</div><div style="font-size:10px;margin-top:8px;color:var(--text-dim)">Vérifie que le Sheets est bien partagé en lecture publique</div>`;
    console.error(e);
  }
}
refresh();
setInterval(refresh, REFRESH_MS);
</script>
</body>
</html>
